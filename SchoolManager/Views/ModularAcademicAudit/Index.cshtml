@model SchoolManager.Services.Interfaces.ModularAcademicAuditResult
@{
    ViewData["Title"] = "Auditoría académica modular";
}

<h1>Auditoría académica modular</h1>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card"><div class="card-body"><h2 class="h6">Estudiantes sin malla</h2><p class="display-6">@Model.StudentsWithoutCurriculum</p></div></div>
    </div>
    <div class="col-md-4">
        <div class="card"><div class="card-body"><h2 class="h6">Materias activas sin trimestre</h2><p class="display-6">@Model.ActiveSubjectsWithoutTrimester</p></div></div>
    </div>
    <div class="col-md-4">
        <div class="card"><div class="card-body"><h2 class="h6">Materias activas sin materia curricular</h2><p class="display-6">@Model.ActiveSubjectsWithoutCurriculumSubject</p></div></div>
    </div>
    <div class="col-md-4">
        <div class="card"><div class="card-body"><h2 class="h6">Créditos creados</h2><p class="display-6">@Model.CreditsCreated</p></div></div>
    </div>
    <div class="col-md-4">
        <div class="card"><div class="card-body"><h2 class="h6">Prerrequisitos faltantes</h2><p class="display-6">@Model.MissingPrerequisiteRows</p></div></div>
    </div>
    <div class="col-md-4">
        <div class="card"><div class="card-body"><h2 class="h6">Estudiantes bloqueados</h2><p class="display-6">@Model.BlockedStudents</p></div></div>
    </div>
    <div class="col-md-4">
        <div class="card"><div class="card-body"><h2 class="h6">Convalidaciones pendientes</h2><p class="display-6">@Model.PendingEquivalencies</p></div></div>
    </div>
</div>
