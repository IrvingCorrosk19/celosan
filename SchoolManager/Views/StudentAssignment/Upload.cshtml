@{
    ViewData["Title"] = "Carga masiva de asignaciones de estudiantes";
    Layout = "_AdminLayout";
}

<style>
    #excelTable tbody tr.error-row {
        background-color: #ffebee !important;
        border-left: 4px solid #f44336 !important;
    }
    #excelTable tbody tr.error-row td {
        color: #f44336 !important;
        font-weight: bold !important;
        background-color: #ffebee !important;
        border-color: #f44336 !important;
    }
</style>

<h3>Cargar y previsualizar archivo Excel</h3>

<div class="alert alert-info mb-3">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div class="flex-grow-1">
            <h5 class="mb-2"><i class="bi bi-info-circle me-2"></i>Carga masiva (colegio nocturna)</h5>
            <p class="mb-2 small text-muted">Una sola pantalla y un solo formato Excel: inscripciones por asignatura (una fila por materia). El turno operativo del sistema sigue siendo <strong>Noche</strong>; la columna Jornada del archivo es informativa u opcional.</p>
            <p class="small mb-1"><strong>Columnas</strong> (orden flexible; deben existir los encabezados con estos nombres):</p>
            <div class="table-responsive small mb-2">
                <table class="table table-bordered table-sm mb-0 bg-white">
                    <thead class="table-light"><tr>
                        <th>Estudiante (Email)</th><th>Nombre</th><th>Apellido</th><th>Documento ID</th><th>Asignatura</th><th>Nivel</th><th>Grupo académico</th><th>Jornada</th><th>Resultado (Inscrito)</th>
                    </tr></thead>
                    <tbody><tr>
                        <td>maria@colegio.edu</td><td>María</td><td>López</td><td>8-1234-567</td><td>Matemática</td><td>10°</td><td>10-A</td><td><em>(opcional)</em></td><td>SI / NO</td>
                    </tr></tbody>
                </table>
            </div>
            <p class="small text-muted mb-0">Obligatorios: email del estudiante, asignatura, nivel, grupo académico y resultado (SI/NO, 1/0, etc.). Opcionales: nombre, apellido, documento, jornada.</p>
        </div>
        <div>
            <a href="@Url.Action("DownloadTemplate", "File", new { fileName = "asignaciones_estudiantes_grado_grupo.xlsx" })"
               class="btn btn-success btn-sm"
               download="asignaciones_estudiantes_grado_grupo.xlsx">
                <i class="bi bi-download me-1"></i>Descargar plantilla
            </a>
        </div>
    </div>
</div>

<input type="file" id="excelFile" class="form-control mb-3" accept=".xlsx,.xls" />

<table id="excelTable" class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Estudiante (Email)</th>
            <th>Nombre</th>
            <th>Apellido</th>
            <th>Documento ID</th>
            <th>Asignatura</th>
            <th>Nivel</th>
            <th>Grupo académico</th>
            <th>Jornada</th>
            <th>Resultado (Inscrito)</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

<div class="text-right mt-3">
    <button id="btnGuardarAsignaciones" class="btn btn-success">Guardar carga masiva</button>
</div>

<div id="loadingOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999;">
    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; color: white;">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <div class="mt-2">Procesando inscripciones...</div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            let payload = [];

            function marcarFilaConError(row) {
                row.addClass('error-row');
            }

            function normalizeHeader(h) {
                return (h ?? "")
                    .toString()
                    .trim()
                    .toUpperCase()
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "")
                    .replace(/\s+/g, " ");
            }

            function parseInscrito(value) {
                if (value === null || value === undefined) return null;
                if (typeof value === 'number') return Math.abs(value) > 0.00001;
                if (typeof value === 'boolean') return value;

                const str = value.toString().trim();
                if (!str) return null;

                const normalized = str
                    .toUpperCase()
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "");

                if (["1", "SI", "SÍ", "TRUE", "INSCRITO", "YES"].includes(normalized)) return true;
                if (["0", "NO", "FALSE", "NO INSCRITO", "N"].includes(normalized)) return false;
                return null;
            }

            $('#excelFile').on('change', function (e) {
                const file = e.target.files[0];
                if (!file) {
                    Swal.fire("Archivo requerido", "Por favor selecciona un archivo Excel (.xlsx o .xls).", "warning");
                    return;
                }

                payload = [];

                const reader = new FileReader();
                reader.onload = function (e) {
                    const data = new Uint8Array(e.target.result);
                    const workbook = XLSX.read(data, { type: 'array' });
                    const sheetName = workbook.SheetNames[0];
                    const sheet = workbook.Sheets[sheetName];
                    const json = XLSX.utils.sheet_to_json(sheet, { header: 1 });

                    if (!json || json.length < 2) {
                        Swal.fire("Excel vacío", "El archivo no contiene filas de datos.", "error");
                        return;
                    }

                    const headersObtenidos = (json[0] || []).map(normalizeHeader);

                    const idxEmail = headersObtenidos.findIndex(h => h === "ESTUDIANTE (EMAIL)" || h === "ESTUDIANTE");
                    const idxNombre = headersObtenidos.findIndex(h => h === "NOMBRE");
                    const idxApellido = headersObtenidos.findIndex(h => h === "APELLIDO");
                    const idxDocumento = headersObtenidos.findIndex(h => h === "DOCUMENTO ID" || h === "DOCUMENTOID");
                    const idxAsignatura = headersObtenidos.findIndex(h => h === "ASIGNATURA");
                    const idxNivel = headersObtenidos.findIndex(h => h === "NIVEL");
                    const idxGrupo = headersObtenidos.findIndex(h => h.includes("GRUPO") && h.includes("ACADEMICO"));
                    const idxJornada = headersObtenidos.findIndex(h => h === "JORNADA");
                    let idxResultado = headersObtenidos.findIndex(h => h.includes("RESULTADO") && h.includes("INSCRITO"));
                    if (idxResultado < 0)
                        idxResultado = headersObtenidos.findIndex(h => h === "RESULTADO");

                    const requeridos = [
                        { idx: idxEmail, label: "Estudiante (Email)" },
                        { idx: idxAsignatura, label: "Asignatura" },
                        { idx: idxNivel, label: "Nivel" },
                        { idx: idxGrupo, label: "Grupo académico" },
                        { idx: idxResultado, label: "Resultado (Inscrito)" }
                    ];
                    const faltantes = requeridos.filter(x => x.idx < 0);
                    if (faltantes.length > 0) {
                        Swal.fire(
                            "Encabezados incorrectos",
                            `Faltan columnas requeridas: ${faltantes.map(f => f.label).join(", ")}`,
                            "error"
                        );
                        return;
                    }

                    const tbody = $('#excelTable tbody');
                    tbody.empty();

                    let erroresDetallados = [];
                    let filasInvalidas = 0;
                    const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

                    for (let i = 1; i < json.length; i++) {
                        const row = json[i];
                        if (!row || row.length === 0) continue;
                        const rowNumber = i + 1;

                        const estudiante = (row[idxEmail] ?? "").toString().trim();
                        const nombre = idxNombre >= 0 ? (row[idxNombre] ?? "").toString().trim() : "";
                        const apellido = idxApellido >= 0 ? (row[idxApellido] ?? "").toString().trim() : "";
                        const documentoId = idxDocumento >= 0 ? (row[idxDocumento] ?? "").toString().trim() : "";
                        const asignatura = (row[idxAsignatura] ?? "").toString().trim();
                        const nivel = (row[idxNivel] ?? "").toString().trim();
                        const grupo = (row[idxGrupo] ?? "").toString().trim();
                        const jornada = idxJornada >= 0 ? (row[idxJornada] ?? "").toString().trim() : "";
                        const inscrito = parseInscrito(row[idxResultado]);
                        const resultadoRaw = (row[idxResultado] ?? "").toString().trim();

                        const camposFaltantes = [];
                        if (!estudiante) camposFaltantes.push("Estudiante (Email)");
                        if (estudiante && !emailRegex.test(estudiante)) camposFaltantes.push("Estudiante (Email) con formato inválido");
                        if (!asignatura) camposFaltantes.push("Asignatura");
                        if (!nivel) camposFaltantes.push("Nivel");
                        if (!grupo) camposFaltantes.push("Grupo académico");
                        if (inscrito === null) camposFaltantes.push("Resultado (Inscrito) con valor SI/NO (o 1/0)");

                        const cells = (vals) => vals.map(v => `<td>${v}</td>`).join("");

                        if (camposFaltantes.length > 0) {
                            filasInvalidas++;
                            erroresDetallados.push(`Fila ${rowNumber}: ${camposFaltantes.join(", ")}`);
                            tbody.append(`<tr>${cells([
                                estudiante || "-",
                                nombre || "-",
                                apellido || "-",
                                documentoId || "-",
                                asignatura || "-",
                                nivel || "-",
                                grupo || "-",
                                jornada || "-",
                                resultadoRaw || "-"
                            ])}</tr>`);
                            marcarFilaConError(tbody.find('tr').last());
                            continue;
                        }

                        payload.push({
                            estudianteEmail: estudiante,
                            nombre: nombre || null,
                            apellido: apellido || null,
                            documentoId: documentoId || null,
                            asignatura: asignatura,
                            nivel: nivel,
                            grupoAcademico: grupo,
                            jornada: jornada || null,
                            inscrito: inscrito
                        });

                        tbody.append(`<tr>${cells([
                            estudiante,
                            nombre || "-",
                            apellido || "-",
                            documentoId || "-",
                            asignatura,
                            nivel,
                            grupo,
                            jornada || "-",
                            inscrito ? "SI" : "NO"
                        ])}</tr>`);
                    }

                    if (filasInvalidas > 0) {
                        Swal.fire({
                            title: "Advertencia",
                            html: `
                                <div class="text-danger mb-2">${filasInvalidas} fila(s) tienen datos incompletos:</div>
                                <div style="max-height: 200px; overflow-y: auto; text-align: left;">
                                    ${erroresDetallados.join("<br>")}
                                </div>
                            `,
                            icon: "warning"
                        });
                    }

                    if ($.fn.DataTable.isDataTable('#excelTable')) {
                        $('#excelTable').DataTable().destroy();
                    }

                    $('#excelTable').DataTable({
                        paging: false,
                        info: false,
                        language: {
                            search: "Buscar:",
                            lengthMenu: "Mostrar _MENU_ registros",
                            paginate: {
                                first: "Primero",
                                last: "Último",
                                next: "Siguiente",
                                previous: "Anterior"
                            },
                            zeroRecords: "No se encontraron resultados",
                            infoEmpty: "Sin registros disponibles",
                            infoFiltered: "(filtrado de _MAX_ registros)"
                        }
                    });
                };

                reader.readAsArrayBuffer(file);
            });

            $('#btnGuardarAsignaciones').on('click', function () {
                if (!payload || payload.length === 0) {
                    Swal.fire("Sin datos válidos", "No hay filas completas para guardar.", "error");
                    return;
                }

                Swal.fire({
                    title: "¿Deseas guardar?",
                    text: `Se van a guardar ${payload.length} fila(s) (inscripciones por materia).`,
                    icon: "question",
                    showCancelButton: true,
                    confirmButtonText: "Sí, guardar",
                    cancelButtonText: "Cancelar"
                }).then(result => {
                    if (result.isConfirmed) {
                        $('#loadingOverlay').show();
                        $('#btnGuardarAsignaciones').prop('disabled', true);

                        $.ajax({
                            url: '@Url.Action("SaveAssignments", "StudentAssignment")',
                            method: 'POST',
                            contentType: 'application/json; charset=utf-8',
                            dataType: 'json',
                            data: JSON.stringify({ mode: 'subjects', subjectRows: payload }),
                            success: function (response) {
                                $('#loadingOverlay').hide();
                                $('#btnGuardarAsignaciones').prop('disabled', false);

                                if (response && response.success === false) {
                                    const msg = response.message || 'La solicitud no pudo completarse.';
                                    const det = response.detail ? `<div class="small text-muted mt-2">${String(response.detail).replace(/</g, '&lt;')}</div>` : '';
                                    Swal.fire({ icon: 'error', title: 'Carga masiva', html: msg + det });
                                    return;
                                }

                                let resumen = `
                                    <b>Activadas/aseguradas:</b> ${response.insertadas || 0}<br>
                                    <b>Desactivadas:</b> ${response.desactivadas || 0}<br>
                                `;

                                if (response.errores && response.errores.length > 0) {
                                    resumen += `<b>Errores:</b><ul>`;
                                    response.errores.slice(0, 10).forEach(err => {
                                        resumen += `<li>${err}</li>`;
                                    });
                                    if (response.errores.length > 10) {
                                        resumen += `<li>...y ${response.errores.length - 10} más.</li>`;
                                    }
                                    resumen += `</ul>`;
                                }

                                Swal.fire({
                                    icon: 'success',
                                    title: 'Resultado de la carga',
                                    html: resumen,
                                    width: '60%',
                                    confirmButtonText: 'Aceptar'
                                });
                            },
                            error: function (xhr) {
                                $('#loadingOverlay').hide();
                                $('#btnGuardarAsignaciones').prop('disabled', false);
                                let msg = 'No se pudo completar la carga masiva.';
                                if (xhr.responseJSON) {
                                    if (xhr.responseJSON.message) msg = xhr.responseJSON.message;
                                    else if (xhr.responseJSON.title) msg = xhr.responseJSON.title;
                                    if (xhr.responseJSON.detail)
                                        msg += '<div class="small text-muted mt-2">' + String(xhr.responseJSON.detail).replace(/</g, '&lt;') + '</div>';
                                    else if (xhr.responseJSON.errors)
                                        msg += '<pre class="small text-start mt-2">' + JSON.stringify(xhr.responseJSON.errors, null, 2).replace(/</g, '&lt;') + '</pre>';
                                } else if (xhr.responseText) {
                                    const t = xhr.responseText.trim();
                                    if (t.length > 0 && t.length < 2000)
                                        msg += '<pre class="small text-start mt-2">' + t.replace(/</g, '&lt;') + '</pre>';
                                }
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error (' + (xhr.status || '?') + ')',
                                    html: msg,
                                    width: '50%'
                                });
                            }
                        });
                    }
                });
            });
        });
    </script>
}
