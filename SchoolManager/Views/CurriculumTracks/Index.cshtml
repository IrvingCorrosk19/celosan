@model IReadOnlyList<SchoolManager.Models.CurriculumTrack>
@{
    ViewData["Title"] = "Mallas curriculares";
    var schools = (IEnumerable<SchoolManager.Models.School>)ViewBag.Schools;
    var academicYears = (IEnumerable<SchoolManager.Models.AcademicYear>)ViewBag.AcademicYears;
    var subjects = (IEnumerable<SchoolManager.Models.Subject>)ViewBag.Subjects;
    var gradeLevels = (IEnumerable<SchoolManager.Models.GradeLevel>)ViewBag.GradeLevels;
    var curriculumSubjects = (IEnumerable<SchoolManager.Models.CurriculumSubject>)ViewBag.CurriculumSubjects;
}

<h1>Mallas curriculares modulares</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<section class="card mb-4">
    <div class="card-body">
        <h2 class="h5">Crear malla</h2>
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-2">
                <div class="col-md-3"><input class="form-control" name="name" placeholder="Nombre" required /></div>
                <div class="col-md-3"><input class="form-control" name="description" placeholder="Descripción" /></div>
                <div class="col-md-3">
                    <select class="form-select" name="schoolId">
                        <option value="">Global</option>
                        @foreach (var school in schools)
                        {
                            <option value="@school.Id">@school.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" name="academicYearId">
                        <option value="">Todos los años</option>
                        @foreach (var year in academicYears)
                        {
                            <option value="@year.Id">@year.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-1"><button class="btn btn-primary w-100">Crear</button></div>
            </div>
        </form>
    </div>
</section>

<section class="card mb-4">
    <div class="card-body">
        <h2 class="h5">Agregar materia curricular</h2>
        <form asp-action="AddSubject" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-2">
                <div class="col-md-3">
                    <select class="form-select" name="curriculumTrackId" required>
                        @foreach (var track in Model)
                        {
                            <option value="@track.Id">@track.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select" name="subjectId" required>
                        @foreach (var subject in subjects)
                        {
                            <option value="@subject.Id">@subject.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" name="gradeLevelId" required>
                        @foreach (var grade in gradeLevels)
                        {
                            <option value="@grade.Id">@grade.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-1"><input class="form-control" name="moduleOrder" type="number" placeholder="Orden" required /></div>
                <div class="col-md-1"><input class="form-control" name="credits" type="number" step="0.1" value="1" /></div>
                <div class="col-md-1"><input class="form-control" name="minimumPassingScore" type="number" step="0.1" value="3.0" /></div>
                <div class="col-md-1"><button class="btn btn-primary w-100">Agregar</button></div>
            </div>
        </form>
    </div>
</section>

<section class="card mb-4">
    <div class="card-body">
        <h2 class="h5">Definir prerrequisito</h2>
        <form asp-action="AddPrerequisite" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-2">
                <div class="col-md-5">
                    <select class="form-select" name="curriculumSubjectId" required>
                        @foreach (var item in curriculumSubjects)
                        {
                            <option value="@item.Id">@item.Subject.Name - @item.GradeLevel.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-5">
                    <select class="form-select" name="prerequisiteCurriculumSubjectId" required>
                        @foreach (var item in curriculumSubjects)
                        {
                            <option value="@item.Id">@item.Subject.Name - @item.GradeLevel.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2"><button class="btn btn-warning w-100">Crear prerrequisito</button></div>
            </div>
        </form>
    </div>
</section>

<table class="table table-striped">
    <thead>
        <tr><th>Malla</th><th>Escuela</th><th>Año</th><th>Materias</th><th>Activa</th></tr>
    </thead>
    <tbody>
        @foreach (var track in Model)
        {
            <tr>
                <td>@track.Name</td>
                <td>@(track.School?.Name ?? "Global")</td>
                <td>@(track.AcademicYear?.Name ?? "Todos")</td>
                <td>@track.CurriculumSubjects.Count</td>
                <td>@(track.IsActive ? "Sí" : "No")</td>
            </tr>
        }
    </tbody>
</table>
