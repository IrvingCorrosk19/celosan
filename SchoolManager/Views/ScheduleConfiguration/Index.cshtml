@model SchoolManager.Models.SchoolScheduleConfiguration
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Configuración de jornada escolar";
}

<div class="content-wrapper">
    <section class="content-header">
        <div class="container-fluid">
            <h1>Configuración de jornada nocturna</h1>
            <p class="text-muted small mb-0">Esta aplicación solo maneja jornada nocturna. El sistema generará únicamente bloques de <strong>Noche</strong>.</p>
            <p class="text-muted small mb-0">Las horas usan <strong>formato 24 h</strong> (18:00, 19:30), estándar en la aplicación.</p>
        </div>
    </section>
    <section class="content">
        <div class="container-fluid">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    @TempData["Success"]
                    <button type="button" class="close" data-dismiss="alert">&times;</button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    @TempData["Error"]
                    <button type="button" class="close" data-dismiss="alert">&times;</button>
                </div>
            }
            <div class="card card-outline card-primary">
                <div class="card-header">
                    <h3 class="card-title">Jornada Nocturna</h3>
                </div>
                <div class="card-body">
                    <form asp-action="SaveConfiguration" method="post">
                        <input type="hidden" asp-for="SchoolId" />
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="MorningStartTime" value="@(Model.NightStartTime?.ToString("HH:mm") ?? Model.MorningStartTime.ToString("HH:mm"))" />
                        <input type="hidden" asp-for="MorningBlockDurationMinutes" value="@(Model.NightBlockDurationMinutes ?? Model.MorningBlockDurationMinutes)" />
                        <input type="hidden" asp-for="MorningBlockCount" value="@(Model.NightBlockCount ?? Model.MorningBlockCount)" />
                        <input type="hidden" asp-for="AfternoonStartTime" value="" />
                        <input type="hidden" asp-for="AfternoonBlockDurationMinutes" value="" />
                        <input type="hidden" asp-for="AfternoonBlockCount" value="" />
                        <input type="hidden" asp-for="RecessAfterAfternoonBlockNumber" />
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class="alert alert-info">
                            <strong>Solo nocturna:</strong> no se crearán bloques de Mañana ni Tarde. Si existen bloques anteriores, al guardar se reemplazarán por bloques de Noche.
                        </div>

                        <h5 class="mb-3">Noche</h5>
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="NightStartTime" class="control-label">Hora de inicio</label>
                                    <input asp-for="NightStartTime" type="text" class="form-control" value="@(Model.NightStartTime?.ToString("HH:mm") ?? "18:00")" placeholder="18:00" pattern="([01]?[0-9]|2[0-3]):[0-5][0-9]" maxlength="5" />
                                    <span asp-validation-for="NightStartTime" class="text-danger"></span>
                                    <small class="form-text text-muted">Formato 24 h (ej. 18:00, 19:30)</small>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label asp-for="NightBlockDurationMinutes" class="control-label">Duración (min)</label>
                                    <input asp-for="NightBlockDurationMinutes" type="number" min="1" max="120" class="form-control" placeholder="45" />
                                    <span asp-validation-for="NightBlockDurationMinutes" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label asp-for="NightBlockCount" class="control-label">Cantidad de bloques</label>
                                    <input asp-for="NightBlockCount" type="number" min="1" max="20" class="form-control" placeholder="6" />
                                    <span asp-validation-for="NightBlockCount" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        <p class="text-muted small">Ej: 18:00, 45 min, 6 bloques → 18:00–18:45, 18:45–19:30, …</p>
                        <div id="nightCalc" class="alert alert-info py-2 small mb-0 mt-2"></div>

                        <hr class="my-4" />
                        <h5 class="mb-3">Recreo nocturno</h5>
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="RecessAfterMorningBlockNumber" class="control-label">Después del bloque n.º</label>
                                    <input asp-for="RecessAfterMorningBlockNumber" type="number" min="1" max="20" class="form-control" placeholder="4" />
                                    <span asp-validation-for="RecessAfterMorningBlockNumber" class="text-danger"></span>
                                    <small class="form-text text-muted">Si coincide con la cantidad de bloques, no se crea recreo intermedio.</small>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="RecessDurationMinutes" class="control-label">Duración (min)</label>
                                    <input asp-for="RecessDurationMinutes" type="number" min="1" max="180" class="form-control" placeholder="30" />
                                    <span asp-validation-for="RecessDurationMinutes" class="text-danger"></span>
                                    <small class="form-text text-muted">Duración del recreo entre clases nocturnas.</small>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />
                        <div class="form-group">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="forceRegenerate" name="forceRegenerate" value="true" />
                                <label class="form-check-label" for="forceRegenerate">
                                    Forzar regeneración: eliminar todas las asignaciones de horario y regenerar bloques (los docentes tendrán que volver a asignar materias).
                                </label>
                            </div>
                            <small class="text-muted">Marque solo si ya hay horarios asignados y desea cambiar la configuración de bloques.</small>
                        </div>

                        <div class="form-group mt-4">
                            <button type="submit" class="btn btn-primary">Guardar y generar bloques</button>
                            <a href="@Url.Action("Index", "TimeSlot")" class="btn btn-secondary">Ver bloques horarios</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            function parseTime(str) {
                if (!str || typeof str !== 'string') return null;
                var parts = str.trim().match(/^(\d{1,2}):(\d{2})/);
                if (!parts) return null;
                return parseInt(parts[1], 10) * 60 + parseInt(parts[2], 10);
            }
            function formatMinutes(min) {
                if (min == null || isNaN(min)) return '--:--';
                var h = Math.floor(min / 60) % 24;
                var m = min % 60;
                return (h < 10 ? '0' : '') + h + ':' + (m < 10 ? '0' : '') + m;
            }
            function updateCalc() {
                var startInput = document.querySelector('input[name="NightStartTime"]');
                var durationInput = document.querySelector('input[name="NightBlockDurationMinutes"]');
                var countInput = document.querySelector('input[name="NightBlockCount"]');
                var recessInput = document.querySelector('input[name="RecessDurationMinutes"]');
                var afterInput = document.querySelector('input[name="RecessAfterMorningBlockNumber"]');
                var aftRecessHidden = document.querySelector('input[name="RecessAfterAfternoonBlockNumber"]');
                var nightDiv = document.getElementById('nightCalc');
                if (!startInput || !durationInput || !countInput || !nightDiv) return;
                var recessMin = Math.max(1, parseInt(recessInput && recessInput.value, 10) || 15);
                var startMin = parseTime(startInput.value);
                var duration = parseInt(durationInput.value, 10) || 0;
                var count = parseInt(countInput.value, 10) || 0;
                if (afterInput) {
                    afterInput.max = String(Math.max(1, count));
                    var ak = parseInt(afterInput.value, 10);
                    if (isNaN(ak) || ak < 1) ak = 1;
                    if (ak > count) { ak = count; afterInput.value = String(count); }
                }
                if (startMin == null || duration < 1 || count < 1) {
                    nightDiv.innerHTML = 'Ingrese hora de inicio, duración y cantidad de bloques para ver el cálculo.';
                    return;
                }
                var k = afterInput ? Math.max(1, Math.min(count, parseInt(afterInput.value, 10) || 3)) : Math.min(3, count);
                var lastClassEndMin = k < count
                    ? startMin + k * duration + recessMin + (count - k) * duration
                    : startMin + count * duration;
                var lastClassTime = formatMinutes(lastClassEndMin);
                var recStartMin = startMin + k * duration;
                var recEndMin = recStartMin + recessMin;
                var html;
                if (k < count) {
                    html = '<strong>Recreo nocturno:</strong> después del <strong>bloque ' + k + '</strong>, de <strong>' + formatMinutes(recStartMin) + '</strong> a <strong>' + formatMinutes(recEndMin) + '</strong> (' + recessMin + ' min). La última clase termina a las <strong>' + lastClassTime + '</strong>.';
                } else {
                    html = '<strong>Sin recreo intermedio</strong> (el recreo está después del último bloque). Fin de la última clase: <strong>' + lastClassTime + '</strong>.';
                }
                nightDiv.innerHTML = html;
                if (aftRecessHidden) aftRecessHidden.value = String(k);
            }
            document.querySelectorAll('input[name="NightStartTime"], input[name="NightBlockDurationMinutes"], input[name="NightBlockCount"], input[name="RecessDurationMinutes"], input[name="RecessAfterMorningBlockNumber"]').forEach(function (el) {
                el.addEventListener('change', updateCalc);
                el.addEventListener('input', updateCalc);
            });
            updateCalc();
        })();
    </script>
}
